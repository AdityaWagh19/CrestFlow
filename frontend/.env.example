# Backend API URL — set to your deployed backend URL in production
VITE_API_URL=http://localhost:3002

# Supabase — anon/publishable key only (safe for frontend)
# Service role key stays in the backend .env and is NEVER here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Admin email — must match ADMIN_EMAIL in backend .env
VITE_ADMIN_EMAIL=admin@yourproject.com
