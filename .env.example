# ─── Algorand Network ─────────────────────────────────────────────────────────
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_PORT=443
ALGOD_TOKEN=

# ─── Accounts ─────────────────────────────────────────────────────────────────
# Deployer: deploys contracts, admin of Escrow + TBill
DEPLOYER_MNEMONIC=word1 word2 ... word25

# Orchestrator: runs automation (investor/redeemer/completer workers)
# Also set as treasury_address in Escrow contract
ORCHESTRATOR_MNEMONIC=word1 word2 ... word25

# Platform receives yield on every completed order
PLATFORM_WALLET_ADDRESS=ALGO_ADDRESS_HERE

# ─── Smart Contract IDs ────────────────────────────────────────────────────────
ESCROW_APP_ID=762218790
TBILL_APP_ID=762214340

# ─── T-Bill ASA IDs (7 maturity tiers) ───────────────────────────────────────
TBILL_1D_ASA=762214378
TBILL_3D_ASA=762214379
TBILL_7D_ASA=762214380
TBILL_14D_ASA=762214381
TBILL_30D_ASA=762214389
TBILL_60D_ASA=762214390
TBILL_90D_ASA=762214391

# ─── Orchestrator Config ──────────────────────────────────────────────────────
# Poll interval in milliseconds (default: 30s)
POLL_INTERVAL_MS=30000
# Minimum order amount in microALGO (default: 5 ALGO = 5000000)
MIN_ORDER_AMOUNT_MICROALGO=5000000

# ─── Backend API ──────────────────────────────────────────────────────────────
BACKEND_PORT=3001
# CHANGE THIS IN PRODUCTION — used to sign JWTs
JWT_SECRET=cadencia-dev-secret-change-in-prod

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://yetssyjyhmujmxefwxvh.supabase.co
# Service role key — used by backend + orchestrator (full DB access, NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Anon/publishable key — used by frontend only (RLS-restricted)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlldHNzeWp5aG11am14ZWZ3eHZoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg3MjUwODQsImV4cCI6MjA5NDMwMTA4NH0.FFTnyf3l1hWq_SzK_-G5cNwQoofXPbhvzJb7KX6Xfyk

# ─── Network ──────────────────────────────────────────────────────────────────
# "testnet" (default) | "mainnet"
NETWORK=testnet

# ─── Visibility / Privacy ─────────────────────────────────────────────────────
# Secret key required for internal admin API endpoints (/platform/stats, /platform/config)
# Send as: X-Admin-Key: <value>
ADMIN_API_KEY=change-me-in-production

# ─── Yield Backend ────────────────────────────────────────────────────────────
# "reserve" (default, current) — pre-funded on-chain reserve, no external DeFi
# "folks-finance" — Folks Finance v2 ALGO lending pool (mainnet Phase 2, stub only)
YIELD_BACKEND=reserve

# ─── Mainnet App IDs (fill in after mainnet contract deploy) ─────────────────
